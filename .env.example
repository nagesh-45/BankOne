# Copy to .env for local docker-compose (do not commit .env)
POSTGRES_DB=bankone
POSTGRES_USER=bankone_user
POSTGRES_PASSWORD=change-me-strong-password

# Backend
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/bankone
SPRING_DATASOURCE_USERNAME=bankone_user
SPRING_DATASOURCE_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRATION=3600000
PORT=8080
# Comma-separated CORS origin patterns (supports *)
APP_CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*

# Frontend build-time API URL (used by Docker web image)
API_BASE_URL=http://localhost:8080
